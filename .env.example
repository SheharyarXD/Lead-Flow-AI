# ── Backend ─────────────────────────────────────────────────────
APP_ID=                   # Application ID
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=             # MySQL connection string (mysql://user:pass@host:port/db)

# ── Frontend (exposed to browser via Vite) ──────────────────────
VITE_KIMI_AUTH_URL=       # Kimi OAuth server URL (e.g. https://auth.kimi.com)
VITE_APP_ID=              # OAuth application ID

# ── Backend (Auth) ─────────────────────────────────────────────
KIMI_AUTH_URL=            # Kimi OAuth server URL (backend)
KIMI_OPEN_URL=            # Kimi Open Platform URL (e.g. https://open.kimi.com)

# ── Admin Role ──────────────────────────────────────────────────
OWNER_UNION_ID=           # Union ID of the app creator; this user gets role "admin" on first login

# ── Server ────────────────────────────────────────────────────────
PORT=                     # HTTP port (default 3000)
PUBLIC_URL=               # Public base URL used to build webhook/redirect URLs (e.g. https://app.example.com)

# ── Twilio (SMS + Voice) ─────────────────────────────────────────
# Platform-wide fallback credentials, used only for organizations that have not
# configured their own Twilio account under Settings > Integrations (BYOK).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=      # Sender number for SMS and inbound voice routing
TWILIO_TWIML_APP_SID=     # TwiML App SID whose Voice Request URL points to {PUBLIC_URL}/api/webhooks/voice — required for browser click-to-call on the platform Twilio account
EMAIL_WEBHOOK_SECRET=     # Shared secret required on the x-webhook-secret header of inbound email webhook calls (production only)

# ── Stripe (Billing) ──────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=    # Signing secret for the /api/webhooks/stripe endpoint
STRIPE_PRICE_STARTER=     # Price ID for the Starter plan
STRIPE_PRICE_PRO=         # Price ID for the Professional plan
STRIPE_PRICE_ENTERPRISE=  # Price ID for the Enterprise plan

# ── File Storage (S3-compatible) ──────────────────────────────────
# Works with AWS S3 or any S3-compatible provider (e.g. Cloudflare R2) — set
# S3_ENDPOINT for non-AWS providers, omit it for AWS.
S3_BUCKET=
S3_REGION=                # Defaults to us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=               # Optional: custom endpoint for R2/MinIO/etc.

# ── AI (OpenAI) ────────────────────────────────────────────────────
# Platform-wide fallback key, used only for organizations that have not
# configured their own OpenAI key under Settings > AI Agent (BYOK).
OPENAI_API_KEY=

# ── Outbound Email (SMTP) ──────────────────────────────────────────
# Platform-wide fallback, used only for organizations that have not configured
# their own SMTP credentials under Settings > Integrations (BYOK).
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
